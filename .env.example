# ══════════════════════════════════════════════════════════════
#  WMS ProOriente — Plantilla de configuración
#  Copiar como .env y ajustar valores
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
#  FASE 1: XAMPP / MySQL (configuración actual)
# ─────────────────────────────────────────────────────────────
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=WMS_PROORIENTE
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ─────────────────────────────────────────────────────────────
#  FASE 2: PostgreSQL (solo cambiar estas 6 líneas)
#  DB_DRIVER=pgsql
#  DB_HOST=your-pg-host
#  DB_PORT=5432
#  DB_NAME=wms_prooriente
#  DB_USER=wms_user
#  DB_PASS=your_secure_password
#  DB_CHARSET=utf8
#  (eliminar DB_COLLATION — no aplica en pgsql)
# ─────────────────────────────────────────────────────────────

# ── JWT ───────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA_32_CHARS_MINIMO
JWT_EXPIRY=28800

# ── Aplicación ────────────────────────────────────────────────
# development | production
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost/WMS_PROORIENTE/public

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ── Integración TMS ───────────────────────────────────────────
TMS_WEBHOOK_URL=https://tu-tms.hostinger.com/webhook
TMS_API_KEY=

# ── Backup ────────────────────────────────────────────────────
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
