# ══════════════════════════════════════════════════════════════
#  WMS Fénix — Plantilla de configuración
#  Copiar como .env y ajustar valores para cada entorno
# ══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
#  ENTORNO LOCAL — XAMPP / MySQL (desarrollo)
# ─────────────────────────────────────────────────────────────
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=WMS_FENIX
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ─────────────────────────────────────────────────────────────
#  ENTORNO PRODUCCIÓN — PostgreSQL 16 (Ubuntu 22.04)
#  Descomentar y completar cuando se migre al servidor:
#
#  DB_DRIVER=pgsql
#  DB_HOST=tu-servidor-pg.example.com    # o IP privada
#  DB_PORT=5432
#  DB_NAME=wms_fenix
#  DB_USER=wms_fenix_user
#  DB_PASS=CLAVE_SEGURA_MINIMO_20_CHARS
#  DB_CHARSET=utf8
#  DB_SSLMODE=require                    # require en producción
#  (eliminar DB_COLLATION — no aplica en pgsql)
# ─────────────────────────────────────────────────────────────

# ── JWT ───────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA_32_CHARS_MINIMO
JWT_EXPIRY=28800

# ── Aplicación ────────────────────────────────────────────────
# development | production
APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost/WMS_FENIX/public
# En producción:
# APP_URL=https://tu-dominio.com/api

# ── CORS ──────────────────────────────────────────────────────
# Separar con comas. En producción usar solo el dominio real.
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ── Integración TMS ───────────────────────────────────────────
TMS_WEBHOOK_URL=
TMS_API_KEY=

# ── Backup ────────────────────────────────────────────────────
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30

# -- IA - Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZAR_CON_TU_API_KEY
